# =============================================================================
# ZX Bank AI — Environment Configuration
# Copy this file to .env and fill in your API key.
# =============================================================================

# --- API Key (REQUIRED) ------------------------------------------------------
# Works with any OpenAI-compatible provider:
#   - Requesty: https://requesty.ai
#   - OpenRouter: https://openrouter.ai
#   - OpenAI directly: https://platform.openai.com
LLM_API_KEY=your_api_key_here

# --- LLM Configuration (optional overrides) ----------------------------------
LLM_MODEL=openai/gpt-4.1-nano

# Default: Requesty router
LLM_BASE_URL=https://router.requesty.ai/v1

# To use OpenRouter instead, change LLM_BASE_URL to:
# LLM_BASE_URL=https://openrouter.ai/api/v1

# To use OpenAI directly, change LLM_BASE_URL to:
# LLM_BASE_URL=https://api.openai.com/v1

ENVIRONMENT=development
